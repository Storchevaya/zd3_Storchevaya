<Window x:Class="zd3_Storchevaya.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Дорожные работы" Height="650" Width="850">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Форма ввода -->
        <GroupBox Header="Добавление объекта" Margin="5">
            <StackPanel>
                <CheckBox x:Name="chkIsReinforced" Content="Усиленная дорога" Margin="5" 
                          Checked="ChkIsReinforced_Checked" Unchecked="ChkIsReinforced_Unchecked"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Строка 0: Местоположение -->
                    <TextBlock Text="Местоположение:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtLocation" Grid.Row="0" Grid.Column="1" Margin="5"/>

                    <!-- Строка 1: Ширина -->
                    <TextBlock Text="Ширина (м):" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtWidth" Grid.Row="1" Grid.Column="1" Margin="5" Text="10"/>

                    <!-- Строка 2: Длина -->
                    <TextBlock Text="Длина (м):" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtLength" Grid.Row="2" Grid.Column="1" Margin="5" Text="100"/>

                    <!-- Строка 3: Масса -->
                    <TextBlock Text="Масса покрытия (кг/м²):" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtMass" Grid.Row="3" Grid.Column="1" Margin="5" Text="200"/>

                    <!-- Строка 4: Дата начала -->
                    <TextBlock Text="Дата начала:" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                    <DatePicker x:Name="dpStartDate" Grid.Row="4" Grid.Column="1" Margin="5" 
                                SelectedDate="{x:Static sys:DateTime.Today}"/>

                    <!-- Строка 5: Удалить по адресу -->
                    <TextBlock Text="Удалить по адресу:" Grid.Row="5" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtDeleteLocation" Grid.Row="5" Grid.Column="1" Margin="5"/>

                    <!-- Строка 6: Кнопки -->
                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="5" HorizontalAlignment="Left">
                        <Button Content="Добавить" Width="100" Margin="5" Click="BtnAdd_Click"/>
                        <Button Content="Удалить выбранный" Width="130" Margin="5" Click="BtnDelete_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Дополнительные поля для усиленной дороги -->
                <StackPanel x:Name="panelReinforced" Visibility="Collapsed" Margin="5">
                    <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                        <StackPanel>
                            <TextBlock Text="Параметры усиленной дороги:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Коэфф. прочности P (1-10):" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtP" Grid.Row="0" Grid.Column="1" Margin="5" Text="5"/>

                                <TextBlock Text="Погодные условия:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtWeather" Grid.Row="1" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="Подрядчик:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtContractor" Grid.Row="2" Grid.Column="1" Margin="5"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Text="* - обязательные поля" FontSize="10" Foreground="Gray" Margin="5"/>
            </StackPanel>
        </GroupBox>

        <!-- Список объектов -->
        <ListBox x:Name="lstRoadWorks" Grid.Row="1" Margin="5" />

        <!-- Панель статистики -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
            <Button Content="Показать статистику (LINQ GroupBy)" Width="220" Margin="5" Click="BtnGroup_Click"/>
            <Button Content="Удалить по местоположению" Width="180" Margin="5" Click="BtnDeleteByLocation_Click"/>
            <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="Blue" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>